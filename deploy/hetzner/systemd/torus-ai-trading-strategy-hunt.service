[Unit]
Description=TorusAiTrading Narrow Strategy Hunt
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=torus
WorkingDirectory=/opt/TorusAiTrading
ExecStart=/usr/bin/bash /opt/TorusAiTrading/runtime/run-strategy-hunt-narrow.sh

[Install]
WantedBy=multi-user.target
